# =============================================================================
# Codirigent Project .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Project-Internal Files (not shared with open-source)
# -----------------------------------------------------------------------------


# Development plans
plans/
docs/superpowers/

# Superpowers skill state
.superpowers/

# Code review results
reviews/

# -----------------------------------------------------------------------------
# Rust / Cargo
# -----------------------------------------------------------------------------

# Build output
target/

# Cargo.lock is included for applications (not libraries)
# Uncomment if you want to ignore it:
# Cargo.lock

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------

# Claude Code
.claude/

# VS Code
.vscode/

# JetBrains (RustRover, IntelliJ)
.idea/
*.iml

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.#*

# Sublime Text
*.sublime-workspace
*.sublime-project

# -----------------------------------------------------------------------------
# Operating System
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory

# -----------------------------------------------------------------------------
# Codirigent Runtime (generated during use)
# -----------------------------------------------------------------------------

# Runtime state (not tracked, regenerated on start)
.codirigent/state.json

# Session notes are optional to track
# Uncomment to ignore:
# .codirigent/sessions/

# -----------------------------------------------------------------------------
# Installer / Build Artifacts
# -----------------------------------------------------------------------------

# MSI build output
dist/

# WiX toolchain (downloaded locally, not committed)
tools/

# WiX intermediate and output files
wix/*.rtf
wix/*.wixobj

# Scripts used only for local release builds
scripts/gen-license-rtf.ps1

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------

# Environment files (may contain secrets)
.env
.env.*
*.env

# Log files
*.log
logs/

# Temporary files
*.tmp
*.temp
tmp/
temp/

# Coverage reports
coverage/
*.lcov
*.gcov

# Profiling data
*.profdata
*.profraw

# Git worktrees
.worktrees/
worktrees/
vibehq-hub/
.docx